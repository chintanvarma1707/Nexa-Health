{
  "name": "nexa-health-monorepo",
  "version": "1.0.0",
  "description": "Premium AI-Powered Healthcare Ecosystem",
  "private": true,
  "scripts": {
    "client": "cd \"Nexa Health\" && npm run dev",
    "server": "cd server-python && python -m uvicorn main:app --reload",
    "dev": "concurrently \"npm run client\" \"npm run server\"",
    "install:all": "npm install && cd \"Nexa Health\" && npm install",
    "lint": "cd \"Nexa Health\" && npm run lint"
  },
  "devDependencies": {
    "concurrently": "^9.1.0"
  },
  "dependencies": {
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.3"
  }
}
