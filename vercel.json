{
  "buildCommand": "cd Sahaara_AI && npm install && npm run build",
  "outputDirectory": "Sahaara_AI/dist",
  "installCommand": "cd Sahaara_AI && npm install",
  "framework": null,
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/index.js" },
    { "source": "/(.*)", "destination": "/index.html" }
  ]
}
