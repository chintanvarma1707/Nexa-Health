{
  "buildCommand": "cd \"Nexa Health\" && npm install && npm run build",
  "outputDirectory": "Nexa Health/dist",
  "installCommand": "cd \"Nexa Health\" && npm install",
  "framework": "vite",
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/server-node/index.js" },
    { "source": "/(.*)", "destination": "/Nexa Health/index.html" }
  ]
}
